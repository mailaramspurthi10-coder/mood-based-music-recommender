[MASTER]
ignore=venv,.venv,build,dist,node_modules
jobs=1
persistent=no
init-hook='import sys, pathlib; sys.path.insert(0, str(pathlib.Path(__file__).resolve().parent / "backend"))'

[MESSAGES CONTROL]
disable=
    missing-module-docstring,
    missing-class-docstring,
    missing-function-docstring,
    too-few-public-methods,
    import-error,
    invalid-name,
    broad-except,
    cyclic-import,
    logging-fstring-interpolation,
    

[REPORTS]
reports=no
score=no

[FORMAT]
max-line-length=100
indent-string='    '

[DESIGN]
max-args=6
max-attributes=10
max-branches=12
max-returns=6
max-statements=120

[TYPECHECK]
ignored-modules=flask_cors

